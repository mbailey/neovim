{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "firefox"
      ]
    },
    "neovim": {
      "command": "neovim-mcp",
      "env": {
        "NVIM_SOCKET_PATH": "/tmp/nvim-cora",
        "ALLOW_SHELL_COMMANDS": "true"
      }
    },
    "agents": {
      "command": "agents",
      "args": [
        "mcp"
      ],
      "env": {
        "CORA_ALLOWED_COOKIE_DOMAINS": "youtube.com,youtu.be"
      }
    },
    "voicemode": {
      "command": "uvx",
      "args": [
        "voice-mode"
      ]
    },
    "tmux": {
      "command": "tmux-python"
    }
  }
}